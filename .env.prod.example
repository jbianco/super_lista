# =============================================================================
# SuperLista — Production Environment Variables
# =============================================================================
# Copy this file to .env.prod and fill in the values:
#   cp .env.prod.example .env.prod && nano .env.prod
# =============================================================================

# Domain where SuperLista will be accessible (required)
DOMAIN=superlista.example.com

# JWT secret key — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-random-secret

# Enable real cart automation (requires Playwright + chromium)
USE_REAL_CART=false

# MercadoLibre API token (optional — without it uses Playwright)
# Get yours at: https://developers.mercadolibre.com.ar/
ML_ACCESS_TOKEN=

# ── GitOps (no tocar en el servidor, se usan desde GitHub Secrets) ──
# These are managed via GitHub Actions secrets, not this file.
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY=
# GHCR_TOKEN=
